{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stackcord.invalid/schemas/provider-mapping.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "work_id",
    "definition_fingerprint",
    "provider",
    "item_id",
    "dependency_items"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "work_id": {
      "type": "string",
      "pattern": "^work\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "definition_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "provider": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "item_id": { "type": "string", "minLength": 1 },
    "dependency_items": {
      "type": "object",
      "propertyNames": {
        "pattern": "^work\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
      },
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
