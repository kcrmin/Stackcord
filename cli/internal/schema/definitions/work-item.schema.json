{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestrator.invalid/schemas/work-item.schema.json",
  "oneOf": [
    { "$ref": "#/$defs/definition" },
    { "$ref": "#/$defs/legacy" }
  ],
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9-]*)+$"
    },
    "work_id": {
      "type": "string",
      "pattern": "^work\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "string_set": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "acceptance": {
      "type": "object",
      "required": ["id", "given", "when", "then", "failure"],
      "properties": {
        "id": { "$ref": "#/$defs/stable_id" },
        "given": { "type": "string", "minLength": 1 },
        "when": { "type": "string", "minLength": 1 },
        "then": { "type": "string", "minLength": 1 },
        "failure": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "repositories",
        "paths",
        "policy_ids",
        "scenario_ids",
        "contract_ids",
        "db_entities",
        "migration_slots",
        "ui_flows",
        "dependency_majors",
        "root_pointers"
      ],
      "properties": {
        "repositories": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "paths": { "$ref": "#/$defs/string_set" },
        "policy_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "scenario_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "contract_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "db_entities": { "$ref": "#/$defs/string_set" },
        "migration_slots": { "$ref": "#/$defs/string_set" },
        "ui_flows": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "dependency_majors": { "$ref": "#/$defs/string_set" },
        "root_pointers": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "kinds",
        "integration_required",
        "user_validation",
        "migration_required",
        "rollback_required"
      ],
      "properties": {
        "kinds": { "$ref": "#/$defs/string_set" },
        "integration_required": { "type": "boolean" },
        "user_validation": { "type": "boolean" },
        "migration_required": { "type": "boolean" },
        "rollback_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "definition": {
      "type": "object",
      "required": [
        "schema_version",
        "id",
        "readiness",
        "title",
        "outcome",
        "acceptance",
        "refs",
        "workspaces",
        "scope",
        "dependencies",
        "merge_order",
        "first_failing_test",
        "evidence"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "id": { "$ref": "#/$defs/work_id" },
        "parent_id": { "$ref": "#/$defs/work_id" },
        "readiness": { "enum": ["draft", "ready"] },
        "title": { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 },
        "acceptance": {
          "type": "array",
          "items": { "$ref": "#/$defs/acceptance" }
        },
        "refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "workspaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "scope": { "$ref": "#/$defs/scope" },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/work_id" },
          "uniqueItems": true
        },
        "merge_order": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "first_failing_test": { "type": "string" },
        "evidence": { "$ref": "#/$defs/evidence" },
        "ui_baselines": {
          "type": "object",
          "propertyNames": { "pattern": "^ui\\.baseline\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
          "additionalProperties": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "legacy": {
      "type": "object",
      "required": ["schema_version", "id", "title", "status", "refs", "dependencies", "updated_at"],
      "properties": {
        "schema_version": { "const": 1 },
        "id": { "type": "string", "pattern": "^work\\.[A-Za-z0-9-]+$" },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["proposed", "ready", "in_progress", "blocked", "review", "done"] },
        "owner": { "type": "string" },
        "refs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
