<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Stackcord" Manufacturer="Stackcord contributors" Version="{{VERSION}}" UpgradeCode="D539A6B1-0C78-45C9-A8A4-5A2CCB8B3027" Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Stackcord">
        <Component Id="StackcordBinary" Guid="*">
          <File Id="StackcordExe" Source="{{BINARY}}" KeyPath="yes" />
          <Environment Id="PathEntry" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
    <Feature Id="ProductFeature" Title="Stackcord" Level="1">
      <ComponentRef Id="StackcordBinary" />
    </Feature>
  </Package>
</Wix>
