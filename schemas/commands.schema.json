{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestrator.invalid/schemas/commands.schema.json",
  "type": "object",
  "required": ["schema_version", "workspace_id", "commands"],
  "properties": {
    "schema_version": { "const": 1 },
    "workspace_id": { "type": "string", "pattern": "^workspace\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "argv", "timeout_seconds"],
        "properties": {
          "id": { "type": "string", "pattern": "^command\\.[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
          "kind": {
            "enum": ["test", "review", "integration", "migration", "rollback", "user", "child-merge", "root-pointer", "security"]
          },
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1, "maxLength": 8192 }
          },
          "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 1800 },
          "environment": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
