{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stackcord.invalid/schemas/release-validation.schema.json",
  "type": "object",
  "required": ["schema_version", "candidate_digest", "confirmed", "evidence_digest", "verified_at"],
  "properties": {
    "schema_version": { "const": 1 },
    "candidate_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "confirmed": { "const": true },
    "evidence_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "verified_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
