{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestrator.invalid/schemas/workspaces.schema.json",
  "type": "object",
  "required": ["schema_version", "project_id", "workspaces"],
  "properties": {
    "schema_version": { "const": 1 },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9-]*)+$"
    },
    "root_remote": { "type": "string", "minLength": 1 },
    "workspaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/workspace" }
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9-]*)+$"
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^(?:/|\\\\)" },
          { "pattern": "(?:^|[/\\\\])\\.\\.(?:$|[/\\\\])" }
        ]
      }
    },
    "workspace": {
      "type": "object",
      "required": ["id", "kind", "path", "responsibilities", "dependencies"],
      "properties": {
        "id": { "$ref": "#/$defs/stable_id" },
        "kind": { "enum": ["root", "directory", "submodule", "external"] },
        "path": { "$ref": "#/$defs/relative_path" },
        "repository": { "type": "string", "minLength": 1 },
        "remote": { "type": "string", "minLength": 1 },
        "responsibilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/stable_id" },
          "uniqueItems": true
        },
        "contract_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "commands_path": { "$ref": "#/$defs/relative_path" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
