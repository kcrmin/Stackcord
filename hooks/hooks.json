{
  "description": "Read-only service context recovery at thread start and after compaction.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "orchestrator hook session-start",
            "commandWindows": "orchestrator.exe hook session-start",
            "timeout": 10,
            "statusMessage": "Checking project continuity"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "orchestrator hook post-compact",
            "commandWindows": "orchestrator.exe hook post-compact",
            "timeout": 10,
            "statusMessage": "Recovering project context"
          }
        ]
      }
    ]
  }
}
